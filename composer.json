{
    "name": "nextcloud/integration_jmapc",
    "description": "JMAP Connector",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Sebastian Krupinski",
            "email": "krupinski01@gmail.com",
            "homepage": "https://github.com/SebastianKrupinski/integration_jmapc",
            "role": "Just another Minion in the cogs of time"
        }
    ],
    "config": {
        "platform": {
            "php": "8.2"
        },
        "sort-packages": true,
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        },
        "optimize-autoloader": true,
        "autoloader-suffix": "jmapc"
    },
    "repositories": [{
        "type": "vcs",
        "url": "https://github.com/sebastiankrupinski/jmap-client-php"
    }],
    "require": {
        "php": ">=8.0 <=8.3",
        "sebastiankrupinski/jmap-client-php": "dev-main"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "OCA\\JMAPC\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\JMAPC\\Tests\\Integration\\": "tests/integration/php/",
            "OCA\\JMAPC\\Tests\\Unit\\": "tests/unit/php/"
        }
    },
    "scripts": {
        "lint": "find . -name \\*.php -not -path './vendor/*' -print0 | xargs -0 -n1 php -l",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "psalm": "psalm.phar --threads=1",
        "psalm:update-baseline": "psalm.phar --threads=1 --update-baseline",
        "psalm:update-baseline:force": "psalm.phar --threads=1 --update-baseline --set-baseline=tests/psalm-baseline.xml",
        "psalm:clear": "psalm.phar --clear-cache && psalm.phar --clear-global-cache",
        "psalm:fix": "psalm.phar --alter --issues=InvalidReturnType,InvalidNullableReturnType,MissingParamType,InvalidFalsableReturnType",
        "test:unit": "phpunit -c tests/unit/php.unit.xml --fail-on-warning",
        "test:integration": "phpunit -c tests/integration/php.integration.xml --fail-on-warning"
    }
}
